{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/src/index.html"
    }
  ]
}
