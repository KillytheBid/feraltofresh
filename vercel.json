{
  "buildCommand": "cd client && npm install && npm run build",
  "installCommand": "npm install && cd client && npm install",
  "public": "client/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
